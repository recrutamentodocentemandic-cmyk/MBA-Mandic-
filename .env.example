# Token do bot criado no @BotFather (Rodrigo guarda; nunca commitar)
TELEGRAM_BOT_TOKEN=

# Chave da API Anthropic
ANTHROPIC_API_KEY=

# Chat IDs (o bot loga o chat_id de qualquer grupo em que for adicionado — ver README)
GROUP_CHAT_ID=          # grupo dos alunos do MBA
MGMT_CHAT_ID=           # grupo do time de gestão (lembretes + relatório semanal)
CURATOR_CHAT_ID=        # chat privado do Rodrigo (curadoria das respostas em modo sombra)

# Modelos (roteamento: Haiku p/ classificação, Sonnet p/ respostas)
CLASSIFIER_MODEL=claude-haiku-4-5
ANSWER_MODEL=claude-sonnet-5

# Caminho do banco SQLite (no Railway, montar um volume em /data)
DB_PATH=./data/bot.db
